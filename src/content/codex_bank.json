        { "id": "c_adv_5", "type": "Transformer", "prompt": "Active Voice", "originalSentence": "The cake was eaten by him.", "targetStructure": "Active Voice", "correctAnswer": "He ate the cake.", "explanation": "Subject performs action." },
        { "id": "c_adv_6", "type": "Transformer", "prompt": "Inversion", "originalSentence": "I have never seen such a sight.", "targetStructure": "Inverted", "correctAnswer": "Never have I seen such a sight.", "explanation": "Emphasis inversion." },
        { "id": "c_adv_7", "type": "Transformer", "prompt": "Relative Clause", "originalSentence": "The car is red. It is mine.", "targetStructure": "Combined (who/which)", "correctAnswer": "The car which is red is mine.", "explanation": "Use relative pronoun." },
