      "questions": [
        { "id": "c_vt_1", "type": "Transformer", "prompt": "Simple Past", "originalSentence": "I eat an apple.", "targetStructure": "Simple Past", "correctAnswer": "I ate an apple.", "explanation": "Past of eat is ate." },
        { "id": "c_vt_2", "type": "Transformer", "prompt": "Present Continuous", "originalSentence": "He plays football.", "targetStructure": "Present Continuous", "correctAnswer": "He is playing football.", "explanation": "am/is/are + verb-ing." },
        { "id": "c_vt_3", "type": "Transformer", "prompt": "Future Simple", "originalSentence": "We study hard.", "targetStructure": "Future Simple", "correctAnswer": "We will study hard.", "explanation": "will + base verb." },
        { "id": "c_vt_4", "type": "Transformer", "prompt": "Past Continuous", "originalSentence": "They sleep.", "targetStructure": "Past Continuous", "correctAnswer": "They were sleeping.", "explanation": "was/were + verb-ing." },
        { "id": "c_vt_5", "type": "Transformer", "prompt": "Present Perfect", "originalSentence": "I finish my work.", "targetStructure": "Present Perfect", "correctAnswer": "I have finished my work.", "explanation": "have/has + past participle." },
        { "id": "c_vt_6", "type": "Transformer", "prompt": "Past Perfect", "originalSentence": "She arrives late.", "targetStructure": "Past Perfect", "correctAnswer": "She had arrived late.", "explanation": "had + past participle." },
        { "id": "c_vt_7", "type": "Transformer", "prompt": "Future Perfect", "originalSentence": "They leave by noon.", "targetStructure": "Future Perfect", "correctAnswer": "They will have left by noon.", "explanation": "will have + past participle." },
        { "id": "c_vt_8", "type": "Transformer", "prompt": "Present Perfect Continuous", "originalSentence": "You wait for an hour.", "targetStructure": "Present Perfect Continuous", "correctAnswer": "You have been waiting for an hour.", "explanation": "have been + verb-ing." },
        { "id": "c_vt_9", "type": "Transformer", "prompt": "Past Perfect Continuous", "originalSentence": "We run slow.", "targetStructure": "Past Perfect Continuous", "correctAnswer": "We had been running slow.", "explanation": "had been + verb-ing." },
        { "id": "c_vt_10", "type": "Transformer", "prompt": "Future Continuous", "originalSentence": "I work tomorrow.", "targetStructure": "Future Continuous", "correctAnswer": "I will be working tomorrow.", "explanation": "will be + verb-ing." },
        { "id": "c_vt_11", "type": "Transformer", "prompt": "Future Perfect Continuous", "originalSentence": "He sleeps for ten hours.", "targetStructure": "Future Perfect Continuous by 8am", "correctAnswer": "He will have been sleeping for ten hours.", "explanation": "will have been + verb-ing." },
        { "id": "c_vt_12", "type": "Transformer", "prompt": "Zero Conditional", "originalSentence": "Ice melts if you heat it.", "targetStructure": "Zero Conditional", "correctAnswer": "Ice melts if you heat it.", "explanation": "Scientific truths." },
        { "id": "c_vt_13", "type": "Transformer", "prompt": "First Conditional", "originalSentence": "It rains, I stay home.", "targetStructure": "First Conditional", "correctAnswer": "If it rains, I will stay home.", "explanation": "Real possibilities." },
        { "id": "c_vt_14", "type": "Transformer", "prompt": "Second Conditional", "originalSentence": "I have money, I travel.", "targetStructure": "Second Conditional", "correctAnswer": "If I had money, I would travel.", "explanation": "Hypothetical present." },
        { "id": "c_vt_15", "type": "Transformer", "prompt": "Third Conditional", "originalSentence": "You study, you pass.", "targetStructure": "Third Conditional", "correctAnswer": "If you had studied, you would have passed.", "explanation": "Hypothetical past." }
      ]
