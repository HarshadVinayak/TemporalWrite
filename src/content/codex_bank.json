      "description": "Noun, Verb, Adjective, etc.",
      "questions": [
        {
          "id": "c_pos_1", "type": "WordBank", "prompt": "Identify the Noun.", "sentence": "The ___ jumped over the fence.", "options": ["quickly", "cat", "happy", "under"], "correctAnswer": "cat", "explanation": "A noun is a naming word."
        },
        {
          "id": "c_pos_2", "type": "WordBank", "prompt": "Identify the Adjective.", "sentence": "The ___ dog barked.", "options": ["big", "run", "it", "with"], "correctAnswer": "big", "explanation": "Adjectives describe nouns."
        },
        { "id": "c_pos_3", "type": "WordBank", "prompt": "Identify the Verb.", "sentence": "She ___ a song.", "options": ["beautiful", "sang", "blue", "slowly"], "correctAnswer": "sang", "explanation": "Verbs are action words." },
        { "id": "c_pos_4", "type": "WordBank", "prompt": "Identify the Adverb.", "sentence": "He ran ___.", "options": ["fast", "car", "yellow", "think"], "correctAnswer": "fast", "explanation": "Adverbs describe actions." },
        { "id": "c_pos_5", "type": "WordBank", "prompt": "Identify the Pronoun.", "sentence": "___ is my friend.", "options": ["She", "Green", "Running", "Table"], "correctAnswer": "She", "explanation": "Pronouns replace nouns." },
        { "id": "c_pos_6", "type": "WordBank", "prompt": "Preposition check.", "sentence": "The book is ___ the table.", "options": ["on", "happy", "read", "very"], "correctAnswer": "on", "explanation": "Prepositions show relationship." },
        { "id": "c_pos_7", "type": "WordBank", "prompt": "Conjunction check.", "sentence": "I like cats ___ dogs.", "options": ["and", "blue", "jump", "loudly"], "correctAnswer": "and", "explanation": "Conjunctions join words." },
        { "id": "c_pos_8", "type": "WordBank", "prompt": "Interjection check.", "sentence": "___! That hurt.", "options": ["Ouch", "House", "Walk", "Pretty"], "correctAnswer": "Ouch", "explanation": "Interjections show emotion." },
        { "id": "c_pos_9", "type": "WordBank", "prompt": "Article check.", "sentence": "___ apple a day...", "options": ["An", "A", "The", "Many"], "correctAnswer": "An", "explanation": "Articles are special adjectives." },
        { "id": "c_pos_10", "type": "WordBank", "prompt": "Abstract Noun.", "sentence": "___ is a virtue.", "options": ["Patience", "Red", "Climb", "Beside"], "correctAnswer": "Patience", "explanation": "Abstract nouns are ideas." },
        { "id": "c_pos_11", "type": "WordBank", "prompt": "Collective Noun.", "sentence": "A ___ of lions.", "options": ["pride", "group", "bunch", "team"], "correctAnswer": "pride", "explanation": "Collective nouns for groups." },
        { "id": "c_pos_12", "type": "WordBank", "prompt": "Proper Noun.", "sentence": "I live in ___.", "options": ["London", "city", "house", "there"], "correctAnswer": "London", "explanation": "Proper nouns are specific." },
        { "id": "c_pos_13", "type": "WordBank", "prompt": "Common Noun.", "sentence": "I bought a ___.", "options": ["book", "London", "running", "happily"], "correctAnswer": "book", "explanation": "Common nouns are general." },
        { "id": "c_pos_14", "type": "WordBank", "prompt": "Helping Verb.", "sentence": "I ___ going now.", "options": ["am", "went", "be", "is"], "correctAnswer": "am", "explanation": "'Am' helps the main verb." },
        { "id": "c_pos_15", "type": "WordBank", "prompt": "Relative Pronoun.", "sentence": "The man ___ saw me.", "options": ["who", "which", "what", "how"], "correctAnswer": "who", "explanation": "Relates back to the noun." }
      ]
